generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                    String                  @id @default(uuid())
  role                  String                  @default("STUDENT")
  name                  String
  phone                 String
  email                 String?                 @unique
  passwordHash          String
  whatsappNumber        String?
  profilePhotoUrl       String?
  schoolOrUniversity    String?
  currentYear           String?
  city                  String?
  area                  String?
  idDocumentUrl         String?
  isApproved            Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  bookings              Booking[]
  enquiriesReceived     Enquiry[]               @relation("OwnerEnquiries")
  enquiriesSent         Enquiry[]               @relation("StudentEnquiries")
  favourites            Favourite[]
  hostels               Hostel[]
  notifications         Notification[]
  notificationPref      NotificationPreference?
  reports               ReportListing[]
  reviews               Review[]
  transactionsVerified  Transaction[]           @relation("VerifiedTransactions")
  transactionsAsStudent Transaction[]           @relation("StudentTransactions")
}

model Hostel {
  id             String          @id @default(uuid())
  ownerId        String
  name           String
  streetAddress  String
  area           String
  campusArea     String?
  category       String
  university     String?
  latitude       Float?
  longitude      Float?
  contactPhone   String
  whatsappNumber String?
  openingHours   String?
  description    String?
  isApproved     Boolean         @default(false)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookings       Booking[]
  enquiries      Enquiry[]
  favourites     Favourite[]
  owner          User            @relation(fields: [ownerId], references: [id])
  paymentConfig  PaymentConfig?
  reports        ReportListing[]
  reviews        Review[]
  rooms          Room[]
  transactions   Transaction[]
}

model Room {
  id          String      @id @default(uuid())
  hostelId    String
  roomType    String
  beds        Int
  monthlyRent Int
  amenities   String
  status      String      @default("AVAILABLE")
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  bookings    Booking[]
  enquiries   Enquiry[]
  hostel      Hostel      @relation(fields: [hostelId], references: [id])
  photos      RoomPhoto[]
}

model RoomPhoto {
  id      String  @id @default(uuid())
  roomId  String
  url     String
  caption String?
  order   Int     @default(0)
  room    Room    @relation(fields: [roomId], references: [id])
}

model Favourite {
  id        String   @id @default(uuid())
  studentId String
  hostelId  String
  createdAt DateTime @default(now())
  hostel    Hostel   @relation(fields: [hostelId], references: [id])
  student   User     @relation(fields: [studentId], references: [id])

  @@unique([studentId, hostelId])
}

model Booking {
  id             String       @id @default(uuid())
  studentId      String
  hostelId       String
  roomId         String
  status         String       @default("PENDING")
  startMonth     String
  durationMonths Int
  note           String?
  createdAt      DateTime     @default(now())
  confirmedAt    DateTime?
  room           Room         @relation(fields: [roomId], references: [id])
  hostel         Hostel       @relation(fields: [hostelId], references: [id])
  student        User         @relation(fields: [studentId], references: [id])
  transaction    Transaction?
}

model Review {
  id         String   @id @default(uuid())
  hostelId   String
  studentId  String
  rating     Int
  comment    String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  student    User     @relation(fields: [studentId], references: [id])
  hostel     Hostel   @relation(fields: [hostelId], references: [id])
}

model Enquiry {
  id            String   @id @default(uuid())
  hostelId      String
  roomId        String?
  studentId     String
  ownerId       String
  message       String
  contactMethod String
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  owner         User     @relation("OwnerEnquiries", fields: [ownerId], references: [id])
  student       User     @relation("StudentEnquiries", fields: [studentId], references: [id])
  room          Room?    @relation(fields: [roomId], references: [id])
  hostel        Hostel   @relation(fields: [hostelId], references: [id])
}

model ReportListing {
  id         String   @id @default(uuid())
  hostelId   String
  reporterId String
  reason     String
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  reporter   User     @relation(fields: [reporterId], references: [id])
  hostel     Hostel   @relation(fields: [hostelId], references: [id])
}

model NotificationPreference {
  id             String  @id @default(uuid())
  userId         String  @unique
  preferredAreas String?
  priceMin       Int?
  priceMax       Int?
  roomTypes      String?
  amenities      String?
  user           User    @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model University {
  id        String   @id @default(uuid())
  name      String   @unique
  city      String?
  country   String?
  createdAt DateTime @default(now())
}

model Transaction {
  id                 String           @id @default(uuid())
  transactionRef     String           @unique
  bookingId          String           @unique
  studentId          String
  hostelId           String
  amount             Int
  paymentMethod      String
  status             String           @default("PENDING")
  receiptUrl         String?
  receiptType        String?
  receiptSubmittedAt DateTime?
  verifiedAt         DateTime?
  verifiedBy         String?
  rejectionReason    String?
  rejectedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  receiptHistory     ReceiptHistory[]
  verifier           User?            @relation("VerifiedTransactions", fields: [verifiedBy], references: [id])
  hostel             Hostel           @relation(fields: [hostelId], references: [id])
  student            User             @relation("StudentTransactions", fields: [studentId], references: [id])
  booking            Booking          @relation(fields: [bookingId], references: [id])
}

model ReceiptHistory {
  id              String      @id @default(uuid())
  transactionId   String
  receiptUrl      String
  receiptType     String
  submittedAt     DateTime    @default(now())
  status          String
  rejectionReason String?
  transaction     Transaction @relation(fields: [transactionId], references: [id])
}

model PaymentConfig {
  id                   String   @id @default(uuid())
  hostelId             String   @unique
  mtnMobileMoneyNumber String?
  airtelMoneyNumber    String?
  bankAccountName      String?
  bankAccountNumber    String?
  bankName             String?
  bankBranch           String?
  cashInstructions     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  hostel               Hostel   @relation(fields: [hostelId], references: [id])
}
